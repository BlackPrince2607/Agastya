{
  "expo": {
    "name": "Agastya",
    "slug": "Agastya",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agastya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05020a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agastya.app",
      "associatedDomains": [
        "applinks:agastya.app",
        "webcredentials:agastya.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Agastya to use your camera to scan your palm for a personalized reading.",
        "NSPhotoLibraryUsageDescription": "Allow Agastya to access your photos so you can upload a palm image.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.agastya.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#05020a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "agastya.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Agastya to use your camera to scan your palm for a personalized reading."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Agastya to access your photos so you can upload a palm image."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#141315",
          "sounds": []
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "agastya",
          "organization": "agastya-ai"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_WITH_EAS_PROJECT_ID"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
