# Copy to `.env` and fill in. Never commit real `.env` to git.

APP_NAME=Agastya API
DEBUG=true

# When DEBUG=true, the API also allows CORS from any localhost/127.0.0.1 port (Expo web often moves ports).

# API prefix (included in main.py router mount)
API_V1_PREFIX=/v1

# Comma-separated — add your Expo dev URLs, LAN IPs for physical devices, and production web origins
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006

# HTTPS Expo tunnels — matched in addition to CORS_ORIGINS (see app/config.py cors_origin_regex)
# CORS_ORIGIN_REGEX=

# Palm: dummy (hash-only motifs) | groq (vision LM when GROQ_API_KEY + palm image present; else dummy)
# PALM_ANALYSIS_MODE=groq

# Groq — palm vision + chat + reports + daily tasks (https://console.groq.com)
# Required for AI dossiers/chat/palm motifs (vision path needs an image capture from the app).
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Supabase — session persistence + palm storage (run supabase/migrations/20260518120000_agastya_sessions.sql)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret (Project Settings → API → JWT Secret) — required for secure /sessions/merge
SUPABASE_JWT_SECRET=
SUPABASE_PALM_BUCKET=palms
