# Copy to `.env` and fill in real values. Never commit `.env` to git.

APP_NAME=Agastya API
# Set DEBUG=false in production — enables extra CORS localhost regex in dev only
DEBUG=false

# API prefix (included in main.py router mount)
API_V1_PREFIX=/v1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Production: replace with your actual web/app origins.
# Expo dev: add LAN IPs as needed.
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,https://agastya.app

# HTTPS Expo tunnels (matched in addition to CORS_ORIGINS):
# CORS_ORIGIN_REGEX=https://.*\.exp\.direct

# ─── Palm Analysis ────────────────────────────────────────────────────────────
# dummy = hash-only (no AI, always works)
# groq  = vision LM when GROQ_API_KEY + image present
# hybrid = CV landmarks + Groq narrative when landmarks supplied
PALM_ANALYSIS_MODE=groq

# Optional Redis URL for shared rate limits across workers (Upstash/Fly Redis)
# REDIS_URL=redis://localhost:6379/0

# Comma-separated trusted hosts for TrustedHostMiddleware (production)
# TRUSTED_HOSTS=api.agastya.app

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Required for AI chat, reports, daily tasks, and palm vision.
# Get keys at https://console.groq.com
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Required for session persistence and palm image storage.
# Run all migrations in supabase/migrations/ before first deploy.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret (Project Settings → API → JWT Secret) — secures /sessions/merge
SUPABASE_JWT_SECRET=
SUPABASE_PALM_BUCKET=palms

# ─── RevenueCat Webhook ───────────────────────────────────────────────────────
# Webhook secret from RevenueCat Dashboard → Integrations → Webhooks → Authorization header.
# The backend verifies this on POST /v1/webhooks/revenuecat to prevent spoofed events.
REVENUECAT_WEBHOOK_SECRET=

# ─── Stripe (web Checkout) ──────────────────────────────────────────────────────
# Secret key from Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe → Developers → Webhooks → endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=
# Price IDs for monthly/annual subscription products (Stripe → Products → Pricing).
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Backend DSN from https://sentry.io → Python project → Client Keys.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
