# Expo / React Native — copy to `.env` in this folder (same level as package.json).
# Restart `expo start` after changing.

# FastAPI base URL (no trailing slash). Emulator defaults work without this file:
# - Android emulator → http://10.0.2.2:8000
# - iOS simulator → http://localhost:8000
# - Expo web (`expo start --web`) → same machine: http://127.0.0.1:8000 ; backend must allow CORS (backend DEBUG=true regex covers any localhost dev port).
# Physical device + PC API (`npm run api`) → use your machine LAN IP:
EXPO_PUBLIC_AGASTYA_API_URL=http://localhost:8000

# Same Supabase project as backend SUPABASE_URL (Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Auth redirect: add agastya://** to Supabase → Authentication → URL Configuration → Redirect URLs

# --- Backend only (backend/.env) — do not expose Groq/ service role keys in Expo ---
# GROQ_API_KEY=              llama chat + dossier JSON + daily tasks + palm vision (see backend/.env.example)
# GROQ_CHAT_MODEL=...
# GROQ_VISION_MODEL=...
# SUPABASE_SERVICE_ROLE_KEY=  persistence + palm uploads (never ship to mobile)
# SUPABASE_JWT_SECRET=        verifies /sessions/merge bearer matches supabase_user_id
# PALM_ANALYSIS_MODE=groq|dummy

EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=premium
# Local dev only: allow paywall to unlock without a store purchase (never ship true to production builds)
EXPO_PUBLIC_ALLOW_DEV_PREMIUM=false

# Analytics — set PostHog OR Mixpanel project token (minimal PII; session/device pseudonyms only).
# PostHog
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Mixpanel (used when PostHog key is unset)
EXPO_PUBLIC_MIXPANEL_TOKEN=
