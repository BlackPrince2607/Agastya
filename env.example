# Expo / React Native — copy to `.env` in this folder (same level as package.json).
# Restart `expo start` after changing. Never commit your real `.env` to git.

# ─── API ──────────────────────────────────────────────────────────────────────
# Production: set to your deployed backend URL (e.g. https://api.agastya.app)
# Emulator defaults when this file is absent:
#   Android emulator → http://10.0.2.2:8000
#   iOS simulator → http://localhost:8000
#   Physical device → auto-detected from Metro LAN host
EXPO_PUBLIC_AGASTYA_API_URL=http://localhost:8000

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API → Project URL and anon/public key
# Use either the legacy anon key (starts with eyJ) or the new publishable key (sb_publishable_).
# Required for Google/Apple OAuth, email magic link, password sign-in, and cross-device sync.
#
# Backend must also set SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, and SUPABASE_JWT_SECRET
# (see backend/.env.example) — without JWT secret, sign-in works but session merge fails.
#
# Email auth is ON when Supabase URL + anon key are set (password + magic link).
# Set EXPO_PUBLIC_EMAIL_SIGNIN=false to hide magic-link option on the password screen.
# Set EXPO_PUBLIC_OAUTH_SIGNIN=false to hide Google/Apple buttons.
#
# Supabase Dashboard → Authentication → URL configuration:
#   Site URL: your app origin (e.g. http://localhost:8081 for Expo web, or https://agastya.app)
#   Redirect URLs (add ALL that apply):
#     http://localhost:8081/auth/callback
#     http://127.0.0.1:8081/auth/callback
#     https://YOUR-VERCEL-DOMAIN/auth/callback
#     agastya://auth/callback
#     agastya://**
#     exp://**          (Expo Go — copy exact URI from Metro / account screen dev card)
#
# EXPO_PUBLIC_EMAIL_SIGNIN=false
# EXPO_PUBLIC_OAUTH_SIGNIN=false
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
#
# Restart with cache clear after changing: npx expo start -c
#
# DEV ONLY: set false while testing real auth flows (Google, magic link, password)
EXPO_PUBLIC_BYPASS_AUTH=false

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# App Store & Google Play API keys from RevenueCat dashboard → App Settings.
# Entitlement ID must match the one created in RevenueCat (default: "premium").
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=premium
# DEV ONLY: bypass paywall without a real purchase (must be false in production mobile builds)
EXPO_PUBLIC_ALLOW_DEV_PREMIUM=false

# DEV ONLY: enter main app without Supabase sign-in
# EXPO_PUBLIC_BYPASS_AUTH=true

# ─── Web / Vercel demo deploy ─────────────────────────────────────────────────
# Add these in Vercel → Project → Settings → Environment Variables (Production).
# EXPO_PUBLIC_* values are baked in at build time — redeploy after changing them.
#
# Web demo (no real billing):
EXPO_PUBLIC_WEB_DEMO=true
#
# Production web billing via Stripe Checkout (set false when using demo bypass):
# EXPO_PUBLIC_STRIPE_CHECKOUT_ENABLED=true
#
# Optional (offline fallbacks work without API):
# EXPO_PUBLIC_AGASTYA_API_URL=https://api.your-domain.com
# EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Sentry (crash / error tracking) ─────────────────────────────────────────
# Create a project at https://sentry.io → React Native.
# DSN is safe to include in the client bundle.
EXPO_PUBLIC_SENTRY_DSN=

# ─── Analytics ────────────────────────────────────────────────────────────────
# Set PostHog OR Mixpanel (PostHog takes priority when both are set).
# PostHog: https://us.i.posthog.com → Project → Settings → Project API Key
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Mixpanel: https://mixpanel.com → Project → Project Token
EXPO_PUBLIC_MIXPANEL_TOKEN=

# ─── Backend-only secrets (never put these in a mobile build) ─────────────────
# See backend/.env.example for GROQ_API_KEY, SUPABASE_SERVICE_ROLE_KEY, etc.
